# Copie ce fichier vers .env et renseigne tes clés (jamais commitées).

# Clé API-Football (dashboard.api-football.com) — plan PRO suffisant.
# Utilisée par src/sync_api_football.py et src/extractor/api_football_extractor.py
API_FOOTBALL_KEY=ta_cle_ici

# Digest quotidien par email (src/models/club_value_finder.py digest) — optionnel.
# EMAIL_ADDRESS : ton adresse Gmail expéditrice.
# EMAIL_APP_PASSWORD : un MOT DE PASSE D'APPLICATION Google, pas ton mot de
#   passe de compte. À générer sur https://myaccount.google.com/apppasswords
#   (nécessite la validation en 2 étapes activée sur le compte Google).
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
